# Anthropic
ANTHROPIC_API_KEY=

# Auth
JWT_SECRET=your-jwt-secret-here

# Pipedrive OAuth
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
PIPEDRIVE_REDIRECT_URI=http://localhost:3001/auth/callback

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL (for LangGraph checkpointer — use Supabase connection pooler)
PG_HOST=
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=
PG_PASSWORD=

# URLs
PUBLIC_SERVER_URL=http://localhost:3001
WEB_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
WEBHOOK_URL=http://localhost:3001/webhooks/pipedrive

# Web (set in apps/web/.env)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_API_URL=http://localhost:3001
